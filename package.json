{
  "name": "bga.fate",
  "version": "1.0.0",
  "description": "",
  "main": "modules/js/Game.js",
  "scripts": {
    "build:ts": "rollup -c",
    "build:scss": "sass --no-source-map src/css/Game.scss fate.css",
    "watch:ts": "rollup -c -w",
    "watch:scss": "sass --watch src/css/Game.scss fate.css",
    "watch": "npm run watch:ts && npm run watch:scss",
    "build": "npm run build:ts && npm run build:scss && npm run genmat",
    "predeploy": "npm run build && npm run lint:php && npm run tests",
    "genmat": "php8.4 misc/other/genmat.php misc/*.csv",
    "lint:php": "find modules/php/ -name '*.php' -exec php -l {} + && echo 'All PHP files OK'",
    "tests": "APP_GAMEMODULE_PATH=~/git/bga-sharedcode/misc/ phpunit --display-deprecations --display-warnings --bootstrap ./modules/php/Tests/_autoload.php  --colors=always modules/php/Tests"
  },
  "author": "Alena Laskavaia",
  "license": "EPL2.0",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.53.3",
    "sass": "^1.71.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "@prettier/plugin-php": "^0.22",
    "jsdom": "^20.0.0",
    "prettier": "^3.6"
  },
  "prettier": {
    "plugins": [
      "@prettier/plugin-php"
    ],
    "braceStyle": "1tbs",
    "printWidth": 140,
    "trailingComma": "none"
  }
}
