{
  "name": "bga.fate",
  "version": "1.0.0",
  "description": "",
  "main": "modules/js/Game.js",
  "scripts": {
    "build:ts": "rollup -c",
    "build:scss": "sass --no-source-map src/css/Game.scss fate.css",
    "watch:ts": "rollup -c -w",
    "watch:scss": "sass --watch src/css/Game.scss fate.css",
    "watch": "npm run watch:ts && npm run watch:scss",
    "build": "npm run build:ts && npm run build:scss && npm run genmat",
    "predeploy": "npm run build && npm run lint:php && npm run tests && npm run jstests",
    "genmat": "php8.4 misc/other/genmat.php misc/*.csv",
    "lint:php": "find modules/php/ -name '*.php' -exec php -l {} + && echo 'All PHP files OK'",
    "test": "APP_GAMEMODULE_PATH=~/git/bga-sharedcode/misc/ phpunit  --testdox --display-deprecations --display-warnings --bootstrap ./modules/php/Tests/_autoload.php  --colors=always",
    "tests": "npm run test -- modules/php/Tests",
    "tests:cov": "XDEBUG_MODE=coverage APP_GAMEMODULE_PATH=~/git/bga-sharedcode/misc/ phpunit --coverage-text",
    "jstests": "TS_NODE_PROJECT=src/tests/tsconfig.json mocha -r ts-node/register -r src/tests/setup.ts src/tests/**/*.spec.ts",
    "play": "php8.4 misc/harness/play.php && ts-node --project misc/harness/tsconfig.json misc/harness/render.ts"
  },
  "author": "Alena Laskavaia",
  "license": "EPL2.0",
  "devDependencies": {
    "@prettier/plugin-php": "^0.22",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^4.3.20",
    "@types/jsdom": "^28.0.0",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.0",
    "chai": "^4.5.0",
    "jsdom": "^20.0.0",
    "mocha": "^10.8.2",
    "prettier": "^3.6",
    "rollup": "^4.53.3",
    "sass": "^1.71.0",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  },
  "prettier": {
    "plugins": [
      "@prettier/plugin-php"
    ],
    "braceStyle": "1tbs",
    "printWidth": 140,
    "trailingComma": "none"
  }
}
